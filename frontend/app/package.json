{
  "name": "finanze",
  "version": "0.7.0",
  "description": "A personal portfolio tracker app that helps you dentralize a variety of assets and investments across different financial entites.",
  "main": "dist-electron/main/index.js",
  "packageManager": "pnpm@10.32.1",
  "keywords": [],
  "author": "marcosav",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:mobile": "pnpm run build:python && vite --host --mode mobile",
    "build": "tsc && vite build",
    "build:python": "node scripts/bundle-python.js",
    "build:mobile": "MOBILE_BUILD=1 pnpm run build && pnpm run build:python",
    "install:pyodide": "node scripts/sync-python-wheels.mjs && node scripts/sync-pyodide.mjs",
    "clean": "node scripts/clean-offline.mjs",
    "preview": "vite preview",
    "dist": "vite build && pnpm exec electron-builder",
    "dist:win": "vite build && pnpm exec electron-builder --win",
    "dist:linux": "vite build && pnpm exec electron-builder --linux",
    "dist:mac:arm64": "vite build && pnpm exec electron-builder --mac --arm64",
    "dist:mac:x64": "vite build && pnpm exec electron-builder --mac --x64",
    "lint": "eslint .",
    "format": "prettier --write .",
    "pretest": "vite build --mode=test",
    "test": "vitest run",
    "lint-staged": "lint-staged --no-stash",
    "native:setup": "bash native/tlsclient/build.sh && bash native/tlsclient/install.sh",
    "native:setup:ios": "bash native/tlsclient/build.sh --platform ios && bash native/tlsclient/install.sh",
    "native:setup:android": "bash native/tlsclient/build.sh --platform android && bash native/tlsclient/install.sh",
    "cap:sync": "pnpm build:mobile && pnpm exec cap sync",
    "cap:ios": "pnpm build:mobile && pnpm exec cap sync ios && pnpm exec cap open ios",
    "cap:android": "pnpm build:mobile && pnpm exec cap sync android && pnpm exec cap open android"
  },
  "lint-staged": {
    "*": "eslint .",
    "*.*": "prettier --check ."
  },
  "dependencies": {
    "@capacitor-community/sqlite": "8.1.0",
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/device": "^8.0.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capgo/capacitor-native-biometric": "^8.4.2",
    "@capgo/capacitor-social-login": "^8.3.9",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.101.1",
    "@tanstack/react-virtual": "^3.13.23",
    "capacitor-plugin-safe-area": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "electron-window-state": "^5.0.3",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.3.0",
    "lucide-react": "^1.7.0",
    "pyodide": "^0.29.2",
    "react-day-picker": "^9.14.0",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.4",
    "tailwindcss-animate": "^1.0.7",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.4",
    "@eslint/css": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@types/node": "^24.10.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "jeep-sqlite": "^2.8.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.18",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.2",
    "vite-plugin-electron": "^0.29.1",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "overrides": {
      "sql.js": "1.11.0",
      "flatted": "3.4.2",
      "lodash": "4.18.0",
      "yaml": "2.8.3",
      "@xmldom/xmldom": "0.8.12",
      "picomatch@2": "2.3.2",
      "picomatch@4": "4.0.4",
      "minimatch@3": "3.1.3",
      "minimatch@5": "5.1.8",
      "minimatch@9": "9.0.7",
      "brace-expansion@1": "1.1.13",
      "brace-expansion@2": "2.0.3",
      "brace-expansion@5": "5.0.5"
    },
    "ignoredBuiltDependencies": [
      "esbuild"
    ],
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller"
    ]
  }
}
